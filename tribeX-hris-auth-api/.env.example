PORT=5000

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key
JWT_SECRET=your_jwt_secret

# Gmail / Nodemailer — use a Gmail App Password (not your account password)
# Enable 2FA on the Gmail account, then go to:
# myaccount.google.com → Security → App passwords → generate one
MAIL_USER=your_gmail@gmail.com
MAIL_PASS=xxxx xxxx xxxx xxxx

# Frontend URL used in email links (verification, password reset).
# Set to your production frontend URL when deployed.
APP_URL=http://localhost:3000
